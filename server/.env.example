ZERO_RETENTION=true
MEMORY_ONLY_PIPELINE=true
RETRY_BUFFER=false
PORT=3000
# 32byte key in hex(64 chars). Required when encrypted secrets are used.
SECRET_KEY=
# Kintone settings (example)
KINTONE_DOMAIN=your-subdomain.cybozu.com
KINTONE_APP_ID=123
KINTONE_API_TOKEN=replace-with-token
KINTONE_TOKEN_FIELD=token
KINTONE_TIMEOUT_MS=10000

# MariaDB connection (example)
DATABASE_URL=mysql://bridge_user:{strong-password}@127.0.0.1:3306/bridge_db
